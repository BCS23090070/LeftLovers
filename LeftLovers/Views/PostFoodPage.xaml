<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LeftLovers.ViewModels"
    x:Class="LeftLovers.Views.PostFoodPage"
    x:DataType="vm:PostFoodViewModel"
    BackgroundColor="#2E7D32">

    <Grid>

        <!-- GREEN HEADER -->
        <Border
            BackgroundColor="#2E7D32"
            Padding="24">

            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Share Food"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Label
                    Text="Help reduce food waste"
                    FontSize="14"
                    TextColor="#D1FAE5" />
            </VerticalStackLayout>
        </Border>

        <!-- CONTENT -->
        <ScrollView Margin="0,110,0,0">
            <VerticalStackLayout Padding="20">

                <Frame
                    BackgroundColor="White"
                    CornerRadius="22"
                    HasShadow="True"
                    Padding="20">

                    <VerticalStackLayout Spacing="16">

                        <Entry
                            Placeholder="Food title"
                            Text="{Binding TitleText}"
                            FontSize="16" />

                        <Editor
                            Placeholder="Describe the food (quantity, condition, notes)"
                            AutoSize="TextChanges"
                            HeightRequest="120"
                            FontSize="15" />

                        <Entry
                            Placeholder="Pickup time (e.g. Before 8 PM)"
                            Text="{Binding PickupTime}"
                            FontSize="15" />

                        <!-- IMAGE PREVIEW -->
                        <Border
                            HeightRequest="200"
                            BackgroundColor="#F3F4F6"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">

                            <Image
                                Source="{Binding ImagePath}"
                                Aspect="AspectFill" />
                        </Border>

                        <Button
                            Text="Select Image"
                            Command="{Binding PickImageCommand}"
                            BackgroundColor="#E8F5E9"
                            TextColor="#2E7D32"
                            CornerRadius="14"
                            FontAttributes="Bold" />

                        <Button
                            Text="Post Food"
                            Command="{Binding SubmitCommand}"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold" />

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
