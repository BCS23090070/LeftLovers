<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:LeftLovers.Models"
    x:Class="LeftLovers.Views.DashboardPage"
    BackgroundColor="#F3F5F4">

    <Grid Padding="16">

        <CollectionView
            ItemsSource="{Binding FoodList}"
            SelectionMode="None">


            <!-- ITEM TEMPLATE -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FoodPost">

                    <Frame
                        Margin="0,0,0,18"
                        Padding="0"
                        CornerRadius="24"
                        HasShadow="True"
                        BackgroundColor="White">

                        <VerticalStackLayout Spacing="0">

                            <!-- IMAGE -->
                            <Grid HeightRequest="230">

                                <Image
                                    Source="{Binding Image}"
                                    Aspect="AspectFill" />

                                <!-- PICKUP TIME BADGE -->
                                <Frame
                                    Padding="10,4"
                                    CornerRadius="14"
                                    BackgroundColor="#E6F4EA"
                                    HasShadow="False"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    Margin="12">

                                    <Label
                                        Text="{Binding PickupTime}"
                                        FontSize="12"
                                        TextColor="#1E7F43"
                                        FontAttributes="Bold" />
                                </Frame>

                            </Grid>

                            <!-- CONTENT -->
                            <VerticalStackLayout Padding="16" Spacing="10">

                                <!-- TITLE -->
                                <Label
                                    Text="{Binding Title}"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827"
                                    LineBreakMode="TailTruncation" />

                                <!-- DESCRIPTION -->
                                <Label
                                    Text="{Binding Description}"
                                    FontSize="14"
                                    TextColor="#6B7280"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation" />

                                <!-- POSTED BY -->
                                <HorizontalStackLayout Spacing="6">

                                    <Label
                                        Text="Posted by"
                                        FontSize="12"
                                        TextColor="#9CA3AF" />

                                    <Label
                                        Text="{Binding OwnerUsername}"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="#374151" />

                                    <Label
                                        Text="•"
                                        FontSize="12"
                                        TextColor="#D1D5DB" />

                                    <Label
                                        Text="{Binding CreatedAt, StringFormat='{0:g}'}"
                                        FontSize="12"
                                        TextColor="#9CA3AF" />

                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
