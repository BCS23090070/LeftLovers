<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:LeftLovers.ViewModels"
    x:Class="LeftLovers.Views.LoginPage"
    x:DataType="vm:LoginViewModel"
    BackgroundColor="#F3F5F4">

    <ContentPage.BindingContext>
        <vm:LoginViewModel />
    </ContentPage.BindingContext>

    <!-- SPLIT SCREEN -->
    <Grid RowDefinitions="*,*"
          Padding="24">

        <!-- ===================== -->
        <!-- 🟢 TOP HALF (BRAND) -->
        <!-- ===================== -->
        <VerticalStackLayout
            Grid.Row="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="6">

            <Label
                Text="LeftLovers"
                FontSize="36"
                FontAttributes="Bold"
                TextColor="#111827"
                HorizontalTextAlignment="Center" />

            <Label
                Text="Share food. Reduce waste."
                FontSize="14"
                TextColor="#6B7280"
                HorizontalTextAlignment="Center" />

        </VerticalStackLayout>

        <!-- ===================== -->
        <!-- ⚪ BOTTOM HALF (LOGIN) -->
        <!-- ===================== -->
        <VerticalStackLayout
            Grid.Row="1"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="340"
            Spacing="18">

            <!-- LOGIN CARD -->
            <Frame
                CornerRadius="24"
                Padding="20"
                BackgroundColor="White"
                HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- EMAIL -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Email"
                            FontSize="12"
                            TextColor="#9CA3AF" />

                        <Entry
                            Placeholder="you@email.com"
                            Keyboard="Email"
                            Text="{Binding Email}"
                            BackgroundColor="#F9FAFB" />
                    </VerticalStackLayout>

                    <!-- PASSWORD -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Password"
                            FontSize="12"
                            TextColor="#9CA3AF" />

                        <Entry
                            Placeholder="••••••••"
                            IsPassword="True"
                            Text="{Binding Password}"
                            BackgroundColor="#F9FAFB" />
                    </VerticalStackLayout>

                    <!-- LOGIN BUTTON -->
                    <Button
                        Text="Log In"
                        HeightRequest="48"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        BackgroundColor="#111827"
                        TextColor="White"
                        Command="{Binding LoginCommand}" />

                </VerticalStackLayout>
            </Frame>

            <!-- CREATE ACCOUNT -->
            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="6">

                <Label
                    Text="New here?"
                    FontSize="13"
                    TextColor="#6B7280" />

                <Label
                    Text="Create account"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="#111827">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>

                </Label>

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
